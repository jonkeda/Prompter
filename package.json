{
  "name": "prompter-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Workspace for the Prompter editor extensions.",
  "workspaces": [
    "extensions/vscode"
  ],
  "scripts": {
    "build": "npm run build:vscode",
    "build:all": "npm run build:vscode && npm run build:visualstudio",
    "build:vscode": "npm --workspace prompter run compile",
    "watch:vscode": "npm --workspace prompter run watch",
    "build:visualstudio": "dotnet build Prompter.sln",
    "restore:visualstudio": "dotnet restore Prompter.sln"
  }
}
